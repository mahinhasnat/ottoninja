#include <SoftwareSerial.h>
#include <Servo.h>

SoftwareSerial BT(2, 3);

Servo myservoLeftFoot;
Servo myservoRightFoot;
Servo myservoLeftLeg;
Servo myservoRightLeg;
Servo myservoLeftArm;
Servo myservoRightArm;
Servo myservoHead;

const uint8_t ServoLeftFootPin  = 5;
const uint8_t ServoRightFootPin = 6;
const uint8_t ServoLeftLegPin   = 7;
const uint8_t ServoRightLegPin  = 8;
const uint8_t ServoLeftArmPin   = 9;
const uint8_t ServoRightArmPin  = 10;
const uint8_t ServoHeadPin      = 11;

int LFFWRS = 20;
int RFFWRS = 20;
int LFBWRS = 20;
int RFBWRS = 20;

int LA0  = 60;
int RA0  = 120;
int LATL = 100;
int RATL = 175;
int LATR = 5;
int RATR = 80;
int LA1  = 180;
int RA1  = 0;

int ModeCounter = 0;
char btCommand = 'S';
int J_x = 0, J_y = 0;

void setup() {
  Serial.begin(9600);
  BT.begin(9600);

  myservoLeftFoot.attach(ServoLeftFootPin,  544, 2400);
  myservoRightFoot.attach(ServoRightFootPin,544, 2400);
  myservoLeftLeg.attach(ServoLeftLegPin,    544, 2400);
  myservoRightLeg.attach(ServoRightLegPin,  544, 2400);
  myservoLeftArm.attach(ServoLeftArmPin,    544, 2400);
  myservoRightArm.attach(ServoRightArmPin,  544, 2400);
  myservoHead.attach(ServoHeadPin,          544, 2400);

  myservoHead.write(90);
  myservoLeftArm.write(90);
  myservoRightArm.write(90);
  delay(300);
  myservoLeftFoot.write(90);
  myservoRightFoot.write(90);
  myservoLeftLeg.write(LA0);
  myservoRightLeg.write(RA0);
  delay(300);
  myservoLeftArm.write(180);
  myservoRightArm.write(0);
  delay(500);
}

void loop() {
  if (BT.available()) {
    btCommand = BT.read();
  }

  if (btCommand == 'X') { NinjaSetRoll(); ModeCounter = 1; }
  if (btCommand == 'Y') { NinjaSetWalk(); ModeCounter = 0; }

  if (btCommand == 'A') NinjaLeftArm();
  else                  NinjaLeftArmDown();

  if (btCommand == 'C') NinjaRightArm();
  else                  NinjaRightArmDown();

  if (ModeCounter == 0) {
    if      (btCommand == 'F') NinjaWalkForward(0);
    else if (btCommand == 'B') NinjaWalkBackward(0);
    else if (btCommand == 'L') NinjaWalkForward(-70);
    else if (btCommand == 'R') NinjaWalkForward(70);
    else if (btCommand == 'S') NinjaWalkStop();
  }

  if (ModeCounter == 1) {
    if      (btCommand == 'F') NinjaRollForward();
    else if (btCommand == 'B') NinjaRollBackward();
    else if (btCommand == 'S') NinjaRollStop();
  }
}

void NinjaSetWalk() {
  myservoLeftLeg.write(LA0);
  myservoRightLeg.write(RA0);
  delay(200);
}

void NinjaSetRoll() {
  myservoLeftLeg.write(LA1);
  myservoRightLeg.write(RA1);
  delay(200);
}

void NinjaWalkForward(int turn) {
  int lt = map(turn, 100, -100, 200, 700);
  int rt = map(turn, 100, -100, 700, 200);

  myservoLeftLeg.write(LATR);
  myservoRightLeg.write(RATR);
  delay(250);

  myservoLeftFoot.write(90 + LFFWRS);
  delay(rt);
  myservoLeftFoot.write(90);

  myservoLeftLeg.write(LATL);
  myservoRightLeg.write(RATL);
  delay(250);

  myservoRightFoot.write(90 - RFFWRS);
  delay(lt);
  myservoRightFoot.write(90);

  myservoLeftLeg.write(LA0);
  myservoRightLeg.write(RA0);
  delay(50);
}

void NinjaWalkBackward(int turn) {
  int lt = map(turn, 100, -100, 200, 700);
  int rt = map(turn, 100, -100, 700, 200);

  myservoLeftLeg.write(LATR);
  myservoRightLeg.write(RATR);
  delay(250);

  myservoLeftFoot.write(90 - LFBWRS);
  delay(rt);
  myservoLeftFoot.write(90);

  myservoLeftLeg.write(LATL);
  myservoRightLeg.write(RATL);
  delay(250);

  myservoRightFoot.write(90 + RFBWRS);
  delay(lt);
  myservoRightFoot.write(90);

  myservoLeftLeg.write(LA0);
  myservoRightLeg.write(RA0);
  delay(50);
}

void NinjaWalkStop() {
  myservoLeftFoot.write(90);
  myservoRightFoot.write(90);
  myservoLeftLeg.write(LA0);
  myservoRightLeg.write(RA0);
}

void NinjaRollForward() {
  myservoLeftFoot.write(90 + LFFWRS);
  myservoRightFoot.write(90 - RFFWRS);
}

void NinjaRollBackward() {
  myservoLeftFoot.write(90 - LFBWRS);
  myservoRightFoot.write(90 + RFBWRS);
}

void NinjaRollStop() {
  myservoLeftFoot.write(90);
  myservoRightFoot.write(90);
}

void NinjaLeftArm()      { myservoLeftArm.write(0); }
void NinjaLeftArmDown()  { myservoLeftArm.write(180); }
void NinjaRightArm()     { myservoRightArm.write(180); }
void NinjaRightArmDown() { myservoRightArm.write(0); }
